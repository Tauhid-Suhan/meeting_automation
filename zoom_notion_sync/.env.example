# ============================================================
#  Zoom → Google Calendar → Notion Sync  |  .env
# ============================================================
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env to git.
# ============================================================

# --- Google Calendar ---
# Path to the credentials JSON downloaded from Google Cloud Console
GOOGLE_CREDENTIALS_PATH=credentials.json
# Token file that will be auto-created after first OAuth login
GOOGLE_TOKEN_PATH=token.json
# Your Google Calendar ID (usually your Gmail address)
GOOGLE_CALENDAR_ID=your_email@gmail.com

# --- Zoom ---
# From https://marketplace.zoom.us → Your App → App Credentials
ZOOM_ACCOUNT_ID=your_zoom_account_id
ZOOM_CLIENT_ID=your_zoom_client_id
ZOOM_CLIENT_SECRET=your_zoom_client_secret

# --- Notion ---
# From https://www.notion.so/my-integrations → New Integration → Secret
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxx
# The ID of your Notion database (from the database URL)
# URL format: https://notion.so/your-workspace/DATABASE_ID?v=...
NOTION_DATABASE_ID=your_notion_database_id

# --- App Settings ---
# How many days ahead to look for upcoming meetings
DAYS_AHEAD=14
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
